# Kopiere diese Datei zu  esphome/secrets.yaml  und fülle sie aus.
# secrets.yaml ist in .gitignore und darf NIEMALS committet werden.

# --- WLAN ---
wifi_ssid: "YOUR_WIFI"
wifi_password: "YOUR_WIFI_PASSWORD"

# --- ESPHome native API (HA) + OTA ---
api_encryption_key: "BASE64_32BYTE_KEY"
ota_password: "OTA_PASSWORD"

# --- STIB Belgian Mobility ---
# Header bmc-partner-key. KEIN OAuth2.
stib_partner_key: "YOUR_STIB_PARTNER_KEY"

# --- Deine Haltepunkte / Station (ermitteln: siehe docs/05-stib-irail.md) ---
stib_point_tram: "YOUR_TRAM_POINTID"
stib_point_bus: "YOUR_BUS_POINTID"
irail_train_station: "YOUR_IRAIL_STATION_ID"
